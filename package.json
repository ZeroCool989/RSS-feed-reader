{
  "name": "frontpage",
  "version": "1.0.0",
  "private": true,
  "description": "Frontpage — your personalized front page for tech content. RSS/Atom feed reader built for the Frontend Mentor product challenge.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
